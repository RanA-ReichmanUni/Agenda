# C# Backend Environment
# Copy this file to .env and fill your values
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
# RabbitMQ connection (can be a full amqp URL or host + creds)
RABBITMQ_URL=
RABBITMQ_HOST=rabbitmq
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Database connection (optional) - if provided, will override appsettings
DATABASE_URL=
